// tracker
#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define INITIAL_CAPACITY 100

typedef struct {
    char name[100];
    char status[20];
    int ep_watched;
    float rating;
} Show;

Show *library = NULL;
int num = 0;
int capacity = 0;

void clear_stdin() {
    int c;
    while ((c = getchar()) != EOF) {
        if (c == '\n') break;
        if (c == '\r') {
            int next = getchar();
            if (next != '\n' && next != EOF)
                ungetc(next, stdin);
            break;
        }
    }
}

int ensure_capacity() {
    if (num < capacity) return 1;
    int new_cap = (capacity == 0) ? INITIAL_CAPACITY : capacity * 2;
    Show *tmp = realloc(library, new_cap * sizeof(Show));
    if (tmp == NULL) return 0;
    library = tmp;
    capacity = new_cap;
    return 1;
}

void save_shows() {
    FILE *f = fopen("shows.txt", "w");
    if (f == NULL) {
        printf("error: could not save to file\n");
        return;
    }
    for (int i = 0; i < num; i++) {
        fprintf(f, "%s|%s|%d|%.1f\n",
                library[i].name,
                library[i].status,
                library[i].ep_watched,
                library[i].rating);
    }
    fclose(f);
}

void load_shows() {
    FILE *f = fopen("shows.txt", "r");
    if (f == NULL) return;
    while (ensure_capacity() &&
           fscanf(f, "%99[^|]|%19[^|]|%d|%f\n",
                  library[num].name,
                  library[num].status,
                  &library[num].ep_watched,
                  &library[num].rating) == 4) {
        num++;
    }
    fclose(f);
}

void delete_show(int idx) {
    for (int i = idx; i < num - 1; i++)
        library[i] = library[i + 1];
    num--;
    save_shows();
}

void edit_show(int idx) {
    printf("\ntitle:");
    scanf("%99[^\n]", library[idx].name);
    clear_stdin();
    printf("\nstatus:");
    scanf("%19s", library[idx].status);
    clear_stdin();
    printf("\nep watched:");
    scanf("%d", &library[idx].ep_watched);
    clear_stdin();
    printf("\nrating:");
    scanf("%f", &library[idx].rating);
    clear_stdin();
    save_shows();
}

void search_shows() {
    char query[100];
    printf("enter title to search:\n");
    scanf("%99[^\n]", query);
    clear_stdin();
    int found = 0;
    for (int i = 0; i < num; i++) {
        if (strstr(library[i].name, query) != NULL) {
            printf("%d) %s - %s - ep%d - %.1f\n",
                   i+1,
                   library[i].name,
                   library[i].status,
                   library[i].ep_watched,
                   library[i].rating);
            found++;
        }
    }
    if (found == 0)
        printf("no matches found\n");
}

void filter_by_status() {
    char query[20];
    printf("enter status to filter by:\n");
    scanf("%19s", query);
    clear_stdin();
    int found = 0;
    for (int i = 0; i < num; i++) {
        if (strcmp(library[i].status, query) == 0) {
            printf("%d) %s - %s - ep%d - %.1f\n",
                   i+1,
                   library[i].name,
                   library[i].status,
                   library[i].ep_watched,
                   library[i].rating);
            found++;
        }
    }
    if (found == 0)
        printf("no matches found\n");
}

int export_list() {
    FILE *f = fopen("my_showList.txt", "w");
    if (f == NULL)
        return 0;
    fprintf(f, "My Show List\n");
    fprintf(f, "==============\n");
    for (int i = 0; i < num; i++) {
        fprintf(f, "%d. %s\n", i+1, library[i].name);
        fprintf(f, " Status: %s\n", library[i].status);
        fprintf(f, " Episodes watched: %d\n", library[i].ep_watched);
        fprintf(f, " Rating: %.1f\n\n", library[i].rating);
    }
    fclose(f);
    return 1;
}

void wait_for_enter() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

int main() {
    int choice;
    setvbuf(stdout, NULL, _IONBF, 0);
    char message[100] = "";
    load_shows();

    do {
        system("clear");
        printf("=== TV/Anime Tracker ===\n");
        if (message[0] != '\0') {
            printf("%s\n", message);
            message[0] = '\0';
        }
        printf("\n");
        printf("press 1 to add show to the list\n");
        printf("press 2 to see list of shows\n");
        printf("press 3 to exit\n");
        printf("press 4 to edit a show\n");
        printf("press 5 to delete a show\n");
        printf("press 6 to search by title\n");
        printf("press 7 to search by status\n");
        printf("press 8 to export list\n");
        scanf("%d", &choice);
        clear_stdin();

        switch (choice) {
            case 1: {
                printf("add show\n");
                if (ensure_capacity()) {
                    Show s;
                    printf("\nTitle:");
                    scanf("%99[^\n]", s.name);
                    clear_stdin();
                    printf("\nstatus:");
                    scanf("%19s", s.status);
                    clear_stdin();
                    printf("\nepisodes watched:");
                    scanf("%d", &s.ep_watched);
                    clear_stdin();
                    printf("\nrating:");
                    scanf("%f", &s.rating);
                    clear_stdin();
                    library[num++] = s;
                    save_shows();
                    strcpy(message, "Show added!");
                } else {
                    strcpy(message, "Out of memory!");
                }
                break;
            }
            case 2: {
                printf("\nlist of shows\n");
                if (num == 0) {
                    printf("no shows added\n");
                } else {
                    for (int i = 0; i < num; i++) {
                        printf("%d) %s - %s - ep%d - %.1f\n",
                               i+1,
                               library[i].name,
                               library[i].status,
                               library[i].ep_watched,
                               library[i].rating);
                    }
                }
                printf("\npress enter to continue...");
                wait_for_enter();
                system("clear");
                break;
            }
            case 3:
                printf("goodbye\n");
                break;
            case 4: {
                int pick;
                printf("Edit\n");
                printf("enter show number to edit:\n");
                scanf("%d", &pick);
                clear_stdin();
                if (pick < 1 || pick > num)
                    strcpy(message, "Invalid number!");
                else {
                    edit_show(pick - 1);
                    strcpy(message, "Show updated!");
                }
                break;
            }
            case 5: {
                int pick;
                printf("Delete\n");
                printf("enter show number to delete:\n");
                scanf("%d", &pick);
                clear_stdin();
                if (pick < 1 || pick > num)
                    strcpy(message, "Invalid number!");
                else {
                    delete_show(pick - 1);
                    strcpy(message, "Show deleted!");
                }
                break;
            }
            case 6:
                search_shows();
                printf("\npress enter to continue...");
                wait_for_enter();
                system("clear");
                break;
            case 7:
                filter_by_status();
                printf("\npress enter to continue...");
                wait_for_enter();
                system("clear");
                break;
            case 8:
                if (export_list())
                    strcpy(message, "Exported to my_showlist.");
                else
                    strcpy(message, "Export failed!");
                break;
            default:
                strcpy(message, "Invalid choice!");
        }
    } while (choice != 3);

    free(library);
    return 0;
}
